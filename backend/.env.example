# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/visionhire?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_in_production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=10485760

# Queue
EVALUATION_QUEUE=evaluation-queue
AUTOSUBMIT_QUEUE=autosubmit-queue
QUEUE_CONCURRENCY=10

# Session
AUTOSAVE_INTERVAL_MS=15000
TIMER_SYNC_INTERVAL_MS=5000
